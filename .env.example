# ── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite   # cheapest/fastest; swap to gemini-2.0-flash for quality

# ── STT ──────────────────────────────────────────────────────────────────────
STT_PROVIDER=faster_whisper           # faster_whisper | deepgram
WHISPER_MODEL=tiny.en                 # tiny.en | base.en | small.en (speed vs quality)
WHISPER_DEVICE=cpu                    # cpu | cuda | auto

# Deepgram fallback (only needed if STT_PROVIDER=deepgram)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── TTS ──────────────────────────────────────────────────────────────────────
TTS_PROVIDER=piper                    # piper | kokoro | elevenlabs | cartesia
PIPER_MODEL_PATH=./models/piper/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=./models/piper/en_US-lessac-medium.onnx.json
KOKORO_MODEL_PATH=./models/kokoro    # path to kokoro model dir

# ── VAD ──────────────────────────────────────────────────────────────────────
VAD_THRESHOLD=0.5                     # Silero VAD confidence threshold (0.0–1.0)
VAD_SILENCE_MS=700                    # ms of silence before endpoint fires
VAD_SPEECH_PAD_MS=100                 # ms of padding added around speech segments

# ── AUDIO ────────────────────────────────────────────────────────────────────
SAMPLE_RATE=16000
CHANNELS=1
CHUNK_MS=30                           # audio chunk size fed to VAD (10/20/30ms)

# ── PIPELINE ─────────────────────────────────────────────────────────────────
LLM_SYSTEM_PROMPT=You are a helpful voice assistant. Give concise, conversational responses. Avoid markdown formatting, bullet points, or lists — speak in natural sentences only.
MAX_HISTORY_TURNS=10                  # conversation turns kept in LLM context

# ── FRONTEND ─────────────────────────────────────────────────────────────────
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=8765                    # open http://127.0.0.1:8765 in your browser

# ── LOGGING ──────────────────────────────────────────────────────────────────
LATENCY_LOG_PATH=./logs/latency.jsonl
LOG_LEVEL=INFO
